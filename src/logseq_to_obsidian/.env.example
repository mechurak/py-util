# Logseq journals 원본 폴더 (YYYY_MM_DD.md 파일들이 있는 곳)
LOGSEQ_JOURNALS_DIR=/path/to/logseq_valut/journals

# Obsidian Journals 출력 폴더 (연도 폴더 + 주간 문서가 생성됨)
OBSIDIAN_JOURNALS_DIR=/path/to/obsidian-vault/Journals

# Logseq pages 원본 폴더 (aws___iam.md 같은 page .md 파일들이 있는 곳)
LOGSEQ_PAGES_DIR=/path/to/obsidian-vault/Logseq Backup

# Obsidian pages 출력 폴더 (변환된 .md 가 생성됨)
OBSIDIAN_PAGES_DIR=/path/to/obsidian-vault/Pages
